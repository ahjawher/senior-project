{
  "id": "ssh_auth",
  "path": "/home/y04/Downloads/secure.log.txt",
  "parser": {
    "type": "regex",
    "patterns": {
      "timestamp": "(\\w+\\s+\\d+\\s+\\d+:\\d+:\\d+)",
      "ip": "(\\d+\\.\\d+\\.\\d+\\.\\d+)",
      "user": "USER=([^\\s]+)",
      "status": "(Failed|Accepted)"
    }
  }
}
